#cloud-config

hostname: {{ vm_name }}
manage_etc_hosts: true
locale: en_US.UTF-8
timezone: UTC

users:
  - name: openclaw
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true
    ssh_authorized_keys:
      - {{ ssh_public_key }}

package_update: true
package_upgrade: false

packages:
  - curl
  - git
  - build-essential
  - jq
  - qemu-guest-agent
  - ufw

write_files:
  - path: /home/openclaw/.openclaw/openclaw.json
    owner: openclaw:openclaw
    permissions: "0600"
    defer: true
    content: |
      {
        "models": {
          "providers": {
            "ollama": {
              "baseUrl": "http://{{ ollama_host }}:{{ ollama_port }}",
              "apiKey": "ollama-local",
              "api": "ollama",
              "models": [
                {
                  "id": "{{ ollama_model }}",
                  "name": "{{ ollama_model }}",
                  "reasoning": false,
                  "input": ["text"],
                  "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
                  "contextWindow": 32768,
                  "maxTokens": 16384
                }
              ]
            }
          }
        },
        "agents": {
          "defaults": {
            "model": {
              "primary": "ollama/{{ ollama_model }}"
            },
            "memorySearch": {
              "provider": "local",
              "local": {
                "modelPath": "/home/openclaw/.openclaw/models/embeddinggemma-300m-qat-Q8_0.gguf"
              }
            }
          }
        },
        "gateway": {
          "port": 18789,
          "bind": "lan",
          "mode": "local",
          "auth": {
            "type": "token",
            "token": "{{ gateway_token }}"
          }
        }
      }

  - path: /etc/systemd/resolved.conf.d/dns-via-host.conf
    permissions: "0644"
    content: |
      # Pin DNS to host dnsmasq (libvirt gateway). Safety net in case DHCP config changes.
      [Resolve]
      DNS=192.168.122.1
      Domains=~.

  - path: /opt/setup-openclaw.sh
    permissions: "0755"
    content: |
      #!/bin/bash
      set -euo pipefail
      exec > /var/log/openclaw-setup.log 2>&1

      echo "[$(date)] Starting OpenClaw setup..."

      # --- VM Firewall: lock down BEFORE any package installs ---
      echo "[$(date)] Configuring VM firewall..."
      ufw default deny incoming
      ufw default deny outgoing

      # Ingress: SSH from host only (for ansible provisioning)
      ufw allow in from 192.168.122.1 to any port 22 proto tcp

      # Egress: Ollama on host
      ufw allow out to 192.168.122.1 port 11434 proto tcp

      # Egress: DNS (host dnsmasq only — pinned to prevent DNS exfiltration)
      ufw allow out to 192.168.122.1 port 53 proto udp
      ufw allow out to 192.168.122.1 port 53 proto tcp

      # Egress: HTTP (needed during setup for apt repos; removed at end of script)
      ufw allow out to any port 80 proto tcp

      # Egress: HTTPS (cloudflared -> Cloudflare edge)
      # NOTE: Broad rule (any IP). Restricting to Cloudflare IP ranges would be brittle.
      # Accepted risk: a compromised process could exfiltrate over HTTPS.
      ufw allow out to any port 443 proto tcp

      # Egress: QUIC (cloudflared prefers UDP 7844 for Cloudflare edge)
      # NOTE: Same accepted-risk as HTTPS. Port 7844 is Cloudflare-specific, limiting utility to attackers.
      ufw allow out to any port 7844 proto udp

      # Loopback: internal services (cloudflared -> gateway on localhost)
      ufw allow in on lo
      ufw allow out on lo

      ufw --force enable
      echo "[$(date)] Firewall enabled (setup mode with HTTP egress)."

      # Install Node.js 22 via NodeSource
      echo "[$(date)] Installing Node.js 22..."
      curl -fsSL https://deb.nodesource.com/setup_22.x | bash -
      apt-get install -y nodejs
      echo "[$(date)] Node.js $(node --version) installed."

      # Install OpenClaw globally
      echo "[$(date)] Installing OpenClaw..."
      npm install -g openclaw@latest
      echo "[$(date)] OpenClaw installed."

      # Ensure config directory ownership
      chown -R openclaw:openclaw /home/openclaw/.openclaw

      # Fix any legacy config issues
      echo "[$(date)] Running OpenClaw doctor..."
      sudo -u openclaw openclaw doctor --fix 2>/dev/null || true

      # Run onboard in non-interactive mode (config already written above)
      echo "[$(date)] Running OpenClaw onboard..."
      sudo -u openclaw openclaw onboard \
        --non-interactive \
        --accept-risk \
        --install-daemon || {
        echo "[$(date)] WARNING: onboard failed, attempting manual daemon install..."
        sudo -u openclaw openclaw gateway install 2>/dev/null || true
      }
      echo "[$(date)] OpenClaw onboard complete."

      # Re-apply our config after onboard (onboard overwrites bind, token, and context settings)
      echo "[$(date)] Re-applying gateway config..."
      sudo -u openclaw python3 -c "
      import json
      f = '/home/openclaw/.openclaw/openclaw.json'
      c = json.load(open(f))
      c['gateway']['bind'] = 'lan'
      c['gateway']['auth'] = {'type': 'token', 'token': '{{ gateway_token }}'}
      for p in c.get('models', {}).get('providers', {}).values():
          for m in p.get('models', []):
              m['contextWindow'] = 32768
              m['maxTokens'] = 16384
      c.setdefault('agents', {}).setdefault('defaults', {})['memorySearch'] = {
          'provider': 'local',
          'local': {
              'modelPath': '/home/openclaw/.openclaw/models/embeddinggemma-300m-qat-Q8_0.gguf'
          }
      }
      json.dump(c, open(f, 'w'), indent=2)
      "
      echo "[$(date)] Gateway config restored."

      # Start the gateway as a system-level service (cloud-init has no user session)
      echo "[$(date)] Creating OpenClaw gateway systemd service..."
      cat > /etc/systemd/system/openclaw-gateway.service << 'SVCEOF'
      [Unit]
      Description=OpenClaw Gateway
      After=network.target

      [Service]
      Type=simple
      User=openclaw
      WorkingDirectory=/home/openclaw
      ExecStart=/usr/bin/openclaw gateway run
      Restart=on-failure
      RestartSec=5
      Environment=HOME=/home/openclaw

      [Install]
      WantedBy=multi-user.target
      SVCEOF
      systemctl daemon-reload
      systemctl enable --now openclaw-gateway.service
      echo "[$(date)] OpenClaw gateway service started."

      # Wait briefly for gateway to bind
      sleep 3
      if curl -s -m 2 http://localhost:18789/ >/dev/null 2>&1; then
        echo "[$(date)] Gateway is responding on port 18789."
      else
        echo "[$(date)] WARNING: Gateway not yet responding on 18789 (may still be starting)."
      fi

      # Install cloudflared
      echo "[$(date)] Installing cloudflared..."
      curl -fsSL https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64.deb \
        -o /tmp/cloudflared.deb
      dpkg -i /tmp/cloudflared.deb
      rm -f /tmp/cloudflared.deb
      echo "[$(date)] cloudflared installed."

      # Install and start the cloudflare tunnel as a service
      echo "[$(date)] Starting cloudflared tunnel..."
      cloudflared service install "{{ cf_tunnel_token }}"
      echo "[$(date)] cloudflared tunnel service installed and started."

      # --- Tighten firewall: remove HTTP egress (only needed for apt during setup) ---
      ufw delete allow out to any port 80 proto tcp
      echo "[$(date)] Firewall tightened (removed HTTP egress)."

      # Signal readiness
      echo "READY" > /var/run/openclaw-ready
      echo "[$(date)] Setup complete. OpenClaw is ready."

runcmd:
  - systemctl enable --now qemu-guest-agent
  - /opt/setup-openclaw.sh
